{
  "name": "in-square/opendxp-favicon-bundle",
  "description": "Favicon generator bundle for OpenDXP.",
  "type": "opendxp-bundle",
  "keywords": ["opendxp", "favicon", "opendxp-bundle"],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/in-square/opendxp-favicon-bundle",
  "authors": [
    {
      "name": "Wladyslaw Dudko",
      "email": "w.dudko@insquare.pl",
      "homepage": "https://insquare.pl/"
    }
  ],
  "require": {
    "php": "^8.3",
    "symfony/framework-bundle": "^7.4",
    "open-dxp/opendxp": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "InSquare\\OpendxpFaviconBundle\\": "src/"
    }
  },
  "extra": {
    "opendxp": {
      "bundles": [
        "InSquare\\OpendxpFaviconBundle\\InSquareOpendxpFaviconBundle"
      ]
    }
  }
}
